# Copy this file to `.env` and fill in the values. The real `.env` is git-ignored.
# Loaded by the API/Worker locally (DotNetEnv) and by docker-compose for ${VAR} substitution.
# Use Section__Key names so ASP.NET Core binds them to configuration.

# ===== Database =====
MSSQL_SA_PASSWORD=your-strong-sa-password
ConnectionStrings__DefaultConnection=Server=localhost,1434;Database=JumpInDb;User Id=sa;Password=your-strong-sa-password;TrustServerCertificate=True;

# ===== JWT (minimum 32 characters) =====
Jwt__Key=replace-with-a-long-random-secret-key

# ===== RabbitMQ =====
RabbitMQ__Username=guest
RabbitMQ__Password=guest

# ===== Stripe (test keys from your Stripe dashboard) =====
Stripe__SecretKey=sk_test_xxx
Stripe__PublishableKey=pk_test_xxx
Stripe__WebhookSecret=

# ===== SMTP (Gmail: use a 16-char App Password; leave blank to disable email) =====
Smtp__Username=your-email@gmail.com
Smtp__Password=your-gmail-app-password
Smtp__SenderEmail=your-email@gmail.com
